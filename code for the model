        ('scaler', StandardScaler()),         # Fitted on train fold only
        ('mlp', MLPRegressor(
            hidden_layer_sizes=(512, 256, 128),
            activation='relu',
            solver='adam',
            alpha=0.001,                      # L2 regularisation
            learning_rate='adaptive',
            learning_rate_init=0.001,
            max_iter=500,
            early_stopping=True,
            validation_fraction=0.1,
            n_iter_no_change=20,              # Patience = 20 epochs
            random_state=SEED,
            verbose=False
        ))
    ])

