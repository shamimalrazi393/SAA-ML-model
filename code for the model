else:
    # ── Load dependencies ─────────────────────────────────────────────────────
    try:
        X_arr; y_barrier; feature_names
    except NameError:
        ckpt = load_checkpoint('feature_matrix')
        if ckpt is None:
            print('ERROR: Feature matrix not found. Run Step 5 first.')
            raise SystemExit
        X_arr         = ckpt['X_arr']
        y_barrier     = ckpt['y_barrier']
        feature_names = ckpt['feature_names']
        X             = pd.DataFrame(X_arr, columns=feature_names)

    # ── Device ────────────────────────────────────────────────────────────────
    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
    print(f'Using device: {device}')

    # ── Physics feature indices ───────────────────────────────────────────────
    # BEP-relevant descriptors used as physics constraints
    bep_feature_candidates = [
        'delta_d_band',
        'delta_cohesive',
        'delta_surface_energy',
        'delta_electroneg',
        'doped_weighted_surface_energy',
        'doped_d-band_center',
    ]
    bep_features = [f for f in bep_feature_candidates if f in feature_names]
    bep_indices  = [feature_names.index(f) for f in bep_features]
    print(f'Physics constraint features ({len(bep_features)}): {bep_features}')

    # ── PINN Architecture ─────────────────────────────────────────────────────
    class PhysicsConstrainedNN(nn.Module):
        """
        Physics-Informed Neural Network for SAA barrier prediction.

        Architecture:
          Main branch: full feature vector → deep MLP → barrier prediction
          Physics branch: BEP descriptors only → linear BEP prior

        Loss = MSE(prediction, true)
             + lambda_bep  * ||prediction - BEP_prior||²   (BEP consistency)
             + lambda_pos  * max(0, -prediction)²           (Ea > 0 constraint)
             + lambda_mono * monotonicity penalty            (SHAP-guided)

        The three constraint terms encode:
          1. BEP consistency: prediction should not deviate too far from
             the linear BEP scaling relation — enforces physical prior
          2. Positivity:  activation barriers must be > 0 eV
          3. Smoothness:  large changes in prediction for small descriptor
             changes are penalised (optional)
        """

        def __init__(self, n_features, n_bep, hidden=(512, 256, 128)):
            super().__init__()

            # Main deep branch
            layers = []
            in_dim = n_features
            for h in hidden:
                layers += [nn.Linear(in_dim, h), nn.ReLU(), nn.Dropout(0.1)]
                in_dim = h
            layers.append(nn.Linear(in_dim, 1))
            self.main_branch = nn.Sequential(*layers)

            # Physics (BEP) branch — linear model on BEP features
            self.bep_branch = nn.Linear(n_bep, 1, bias=True)

        def forward(self, x, x_bep):
            pred     = self.main_branch(x).squeeze(-1)
            bep_pred = self.bep_branch(x_bep).squeeze(-1)
            return pred, bep_pred

    def physics_loss(pred, bep_pred, y_true,
                     lambda_bep=0.1, lambda_pos=1.0):
        """
        Combined loss with physics constraints.

        Terms:
          mse_loss    : standard prediction accuracy
          bep_loss    : prediction should be consistent with BEP prior
          pos_loss    : Ea must be positive (physical constraint)
          bep_train   : BEP branch itself trained on true y (auxiliary)
        """
        mse_loss = nn.MSELoss()(pred, y_true)
        bep_loss = lambda_bep * nn.MSELoss()(pred, bep_pred.detach())
        pos_loss = lambda_pos * torch.mean(torch.clamp(-pred, min=0) ** 2)
        bep_train= nn.MSELoss()(bep_pred, y_true)

        total = mse_loss + bep_loss + pos_loss + bep_train
        return total, {
            'mse':  mse_loss.item(),
            'bep':  bep_loss.item(),
            'pos':  pos_loss.item(),
            'total':total.item()
        }

    # ── Training function ──────────────────────────────────────────────────────
    def train_pinn(X_tr, X_te, y_tr, y_te,
                   bep_idx, n_epochs=150,
                   lr=1e-3, batch_size=256,
                   lambda_bep=0.1, lambda_pos=1.0,
                   verbose=True):

        scaler = StandardScaler()
        X_tr_s = scaler.fit_transform(X_tr)
        X_te_s = scaler.transform(X_te)

        X_tr_t  = torch.tensor(X_tr_s, dtype=torch.float32).to(device)
        X_te_t  = torch.tensor(X_te_s, dtype=torch.float32).to(device)
        y_tr_t  = torch.tensor(y_tr,   dtype=torch.float32).to(device)
        y_te_t  = torch.tensor(y_te,   dtype=torch.float32).to(device)

        X_bep_tr = X_tr_t[:, bep_idx]
        X_bep_te = X_te_t[:, bep_idx]

        dataset = TensorDataset(X_tr_t, X_bep_tr, y_tr_t)
        loader  = DataLoader(dataset, batch_size=batch_size, shuffle=True)

        model = PhysicsConstrainedNN(
            n_features=X_tr_s.shape[1],
            n_bep=len(bep_idx)
        ).to(device)

        optimizer = optim.Adam(model.parameters(), lr=lr,
                               weight_decay=1e-4)
        scheduler = optim.lr_scheduler.ReduceLROnPlateau(
            optimizer, patience=10, factor=0.5)

        best_val_loss = float('inf')
        patience_count = 0
        patience_limit  = 20

        for epoch in range(n_epochs):
            model.train()
            epoch_losses = []

            for xb, xb_bep, yb in loader:
                optimizer.zero_grad()
                pred, bep_pred = model(xb, xb_bep)
                loss, _ = physics_loss(pred, bep_pred, yb,
                                       lambda_bep=lambda_bep,
                                       lambda_pos=lambda_pos)
                loss.backward()
                nn.utils.clip_grad_norm_(model.parameters(), 1.0)
                optimizer.step()
                epoch_losses.append(loss.item())

            # Validation
            model.eval()
            with torch.no_grad():
                pred_te, bep_te = model(X_te_t, X_bep_te)
                val_loss, loss_parts = physics_loss(
                    pred_te, bep_te, y_te_t,
                    lambda_bep=lambda_bep,
                    lambda_pos=lambda_pos)
                val_mae = torch.mean(
                    torch.abs(pred_te - y_te_t)).item()

            scheduler.step(val_loss)

            if val_loss < best_val_loss:
                best_val_loss  = val_loss.item()
                best_pred      = pred_te.cpu().numpy()
                patience_count = 0
            else:
                patience_count += 1

            if verbose and (epoch + 1) % 25 == 0:
                print(f'  Epoch {epoch+1:3d}/{n_epochs} | '
                      f'Train loss={np.mean(epoch_losses):.4f} | '
                      f'Val MAE={val_mae:.4f} eV | '
                      f'MSE={loss_parts["mse"]:.4f} | '
                      f'BEP={loss_parts["bep"]:.4f} | '
                      f'Pos={loss_parts["pos"]:.4f}')

            if patience_count >= patience_limit:
                if verbose:
                    print(f'  Early stop at epoch {epoch+1}')
                break

        return best_pred, model

