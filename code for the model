    # ── Settings ──────────────────────────────────────────────────────────────
    N_TREES_FOR_INTERACTION = 100
    N_SAMPLES               = 100

    # ── Build lighter RF using first N trees ──────────────────────────────────
    rf_light              = copy.copy(rf_final_barrier)
    rf_light.estimators_  = rf_final_barrier.estimators_[:N_TREES_FOR_INTERACTION]
    rf_light.n_estimators = N_TREES_FOR_INTERACTION

    # ── Sample selection ──────────────────────────────────────────────────────
    sample_idx_small = np.random.choice(len(X_arr), N_SAMPLES, replace=False)
    X_small          = X.iloc[sample_idx_small]

    # ── Build TreeExplainer ───────────────────────────────────────────────────
    print(f'Building TreeExplainer ({N_TREES_FOR_INTERACTION} trees)...')
    t0                 = time.time()
    explainer_interact = shap.TreeExplainer(rf_light)
    t_exp              = time.time() - t0
    print(f'✓ Built in {int(t_exp//60)}m{int(t_exp%60):02d}s')
    print()

    # ── Benchmark 1 sample ────────────────────────────────────────────────────
    print('Benchmarking 1 sample to estimate total time...')
    t0           = time.time()
    _            = explainer_interact.shap_interaction_values(X_small.iloc[[0]])
    t_per_sample = time.time() - t0
    t_total_est  = t_per_sample * N_SAMPLES

    print(f'  1 sample took         : {t_per_sample:.2f}s')
    print(f'  {N_SAMPLES} samples estimate  : '
          f'~{int(t_total_est//60)}m{int(t_total_est%60):02d}s')
    print()

    # ── Compute sample by sample with tqdm ────────────────────────────────────
    print(f'Computing SHAP interaction values '
          f'({N_SAMPLES} samples, {N_TREES_FOR_INTERACTION} trees)...')
    shap_chunks = []
    start_time  = time.time()

    for i in tqdm(range(N_SAMPLES),
                  desc='SHAP Interactions',
                  unit='sample',
                  ncols=80):
        chunk = explainer_interact.shap_interaction_values(
            X_small.iloc[[i]])
        shap_chunks.append(chunk)

    elapsed = time.time() - start_time
    print(f'✓ Done in {int(elapsed//60)}m{int(elapsed%60):02d}s')

    shap_interact = np.vstack(shap_chunks)

    # ── Build interaction matrix ──────────────────────────────────────────────
    interact_matrix = np.abs(shap_interact).mean(axis=0)
    interact_df     = pd.DataFrame(
        interact_matrix,
        index=feature_names,
        columns=feature_names)
    np.fill_diagonal(interact_df.values, 0)

