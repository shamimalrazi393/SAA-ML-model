def save_checkpoint(obj, name):
    """Save any object to Drive — model, dict, list, or dataframe."""
    path = f'{SAVE_DIR}/results/{name}.joblib'
    joblib.dump(obj, path)
    print(f'  ✓ Checkpoint saved: {name}')

def load_checkpoint(name):
    """Load a checkpoint if it exists. Returns None if not found."""
    path = f'{SAVE_DIR}/results/{name}.joblib'
    if os.path.exists(path):
        obj = joblib.load(path)
        print(f'  ✓ Checkpoint loaded: {name}')
        return obj
    return None

def checkpoint_exists(name):
    """Check if a checkpoint already exists on Drive."""
    return os.path.exists(f'{SAVE_DIR}/results/{name}.joblib')

def save_figure(fig, name):
    """Save a matplotlib figure as PDF and PNG to Drive."""
    fig.savefig(f'{SAVE_DIR}/figures/{name}.pdf', dpi=300, bbox_inches='tight')
    fig.savefig(f'{SAVE_DIR}/figures/{name}.png', dpi=200, bbox_inches='tight')
    print(f'  ✓ Figure saved: {name}.pdf / .png')

def save_csv(df, name):
    """Save a dataframe as CSV to Drive."""
    path = f'{SAVE_DIR}/results/{name}.csv'
    df.to_csv(path, index=False)
    print(f'  ✓ CSV saved: {name}.csv')

