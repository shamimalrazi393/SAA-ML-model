from sklearn.ensemble import RandomForestRegressor
from sklearn.model_selection import cross_val_score
from matminer.featurizers.composition import ElementProperty, Miedema
from pymatgen.core import Composition
from tqdm.notebook import tqdm
import warnings
warnings.filterwarnings('ignore')

matminer_ckpt = load_checkpoint('matminer_features')

if matminer_ckpt is not None:
    X_matminer             = matminer_ckpt['X_matminer']
    matminer_feature_names = matminer_ckpt['matminer_feature_names']
    X_arr_combined         = matminer_ckpt['X_arr_combined']
    feature_names_combined = matminer_ckpt['feature_names_combined']
    print('✓ matminer features loaded from Drive.')
    print(f'  matminer features : {X_matminer.shape}')
    print(f'  Combined matrix   : {X_arr_combined.shape}')

else:
    # ── Load feature matrix ───────────────────────────────────────────────────
    try:
        X_arr
        feature_names
        y_barrier
        host_labels
        surface_labels
        X
    except NameError:
        ckpt = load_checkpoint('feature_matrix')
        if ckpt is None:
            print('ERROR: feature_matrix checkpoint not found.')
            print('Run Step 5 first before running Step 5b.')
            raise SystemExit
        X_arr          = ckpt['X_arr']
        feature_names  = ckpt['feature_names']
        y_barrier      = ckpt['y_barrier']
        y_rate         = ckpt['y_rate']
        host_labels    = ckpt['host_labels']
        surface_labels = ckpt['surface_labels']
        X              = pd.DataFrame(X_arr, columns=feature_names)
        print(f'✓ Feature matrix loaded: {X_arr.shape}')

    # ── Load original CSV ─────────────────────────────────────────────────────
    drive_csv = f'{SAVE_DIR}/Database.csv'
    try:
        df_orig = pd.read_csv(io.BytesIO(uploaded[filename]))
        if not os.path.exists(drive_csv):
            df_orig.to_csv(drive_csv, index=False)
    except Exception:
        if os.path.exists(drive_csv):
            df_orig = pd.read_csv(drive_csv)
        else:
            print(f'ERROR: Database.csv not found at {drive_csv}')
            raise SystemExit

    print(f'Dataset loaded     : {df_orig.shape}')
    print(f'Unique hosts       : {df_orig["Host"].nunique()}')
    print(f'Unique dopants     : {df_orig["Doped"].nunique()}')

    # ── Magpie descriptors ────────────────────────────────────────────────────
    ep = ElementProperty.from_preset('magpie')

    def get_magpie(symbol):
        try:
            return ep.featurize(Composition(symbol))
        except Exception:
            return [np.nan] * len(ep.feature_labels())

    print(f'\nComputing Magpie descriptors...')
    print(f'  Features per element : {len(ep.feature_labels())}')

    print('  Host metals:')
    host_magpie = [get_magpie(h) for h in
                   tqdm(df_orig['Host'].values,
                        desc='  Host Magpie', ncols=80)]

    print('  Dopant metals:')
    doped_magpie = [get_magpie(d) for d in
                    tqdm(df_orig['Doped'].values,
                         desc='  Dopant Magpie', ncols=80)]

    host_magpie_df = pd.DataFrame(
        host_magpie,
        columns=[f'host_magpie_{l}' for l in ep.feature_labels()])
    doped_magpie_df = pd.DataFrame(
        doped_magpie,
        columns=[f'doped_magpie_{l}' for l in ep.feature_labels()])

    # ── Delta Magpie (dopant - host) ──────────────────────────────────────────
    print('\nComputing delta Magpie features (dopant - host)...')
    delta_magpie_df = pd.DataFrame()
    for l in ep.feature_labels():
        hcol = f'host_magpie_{l}'
        dcol = f'doped_magpie_{l}'
        if hcol in host_magpie_df.columns and \
           dcol in doped_magpie_df.columns:
            delta_magpie_df[f'delta_magpie_{l}'] = (
                doped_magpie_df[dcol].values -
                host_magpie_df[hcol].values)

    # ── Miedema CALPHAD mixing enthalpy ───────────────────────────────────────
    print('\nComputing Miedema mixing enthalpy (CALPHAD proxy)...')
    miedema      = Miedema()
    miedema_vals = []

    for host, doped in tqdm(
            zip(df_orig['Host'].values, df_orig['Doped'].values),
            total=len(df_orig), desc='  Miedema', ncols=80):
        try:
            if host == doped:
                # Same-element: mixing enthalpy = 0 by definition
                miedema_vals.append(
                    [0.0] * len(miedema.feature_labels()))
            else:
                comp = Composition({host: 0.5, doped: 0.5})
                miedema_vals.append(miedema.featurize(comp))
        except Exception:
            miedema_vals.append(
                [np.nan] * len(miedema.feature_labels()))

    miedema_df = pd.DataFrame(
        miedema_vals,
        columns=[f'calphad_{l}' for l in miedema.feature_labels()])

    # ── Combine all matminer features ─────────────────────────────────────────
    print('\nCombining all matminer features...')
    X_matminer = pd.concat([
        host_magpie_df.reset_index(drop=True),
        doped_magpie_df.reset_index(drop=True),
        delta_magpie_df.reset_index(drop=True),
        miedema_df.reset_index(drop=True),
    ], axis=1)

    # Remove constant columns
    constant_cols = [c for c in X_matminer.columns
                     if X_matminer[c].std() == 0]
    X_matminer    = X_matminer.drop(columns=constant_cols)
    print(f'  Removed {len(constant_cols)} constant columns.')

    # Fill NaN with median
    X_matminer             = X_matminer.fillna(X_matminer.median())
    matminer_feature_names = X_matminer.columns.tolist()

    print(f'\nmatminer feature summary:')
    print(f'  Magpie host     : '
          f'{len([c for c in matminer_feature_names if c.startswith("host_magpie_")])} features')
    print(f'  Magpie dopant   : '
          f'{len([c for c in matminer_feature_names if c.startswith("doped_magpie_")])} features')
    print(f'  Delta Magpie    : '
          f'{len([c for c in matminer_feature_names if c.startswith("delta_magpie_")])} features')
    print(f'  Miedema CALPHAD : '
          f'{len([c for c in matminer_feature_names if c.startswith("calphad_")])} features')
    print(f'  Total matminer  : {X_matminer.shape[1]} features')

    # ── Merge with existing feature matrix ────────────────────────────────────
    print('\nMerging with existing feature matrix...')
    X_combined = pd.concat([
        X.reset_index(drop=True),
        X_matminer.reset_index(drop=True)
    ], axis=1)

    # Remove duplicate columns
    X_combined             = X_combined.loc[
        :, ~X_combined.columns.duplicated()]
    X_combined             = X_combined.fillna(X_combined.median())
    X_arr_combined         = X_combined.values
    feature_names_combined = X_combined.columns.tolist()

    print(f'  Original features : {X_arr.shape[1]}')
    print(f'  matminer features : {X_matminer.shape[1]}')
    print(f'  Combined features : {X_arr_combined.shape[1]}')
    print(f'  Total samples     : {X_arr_combined.shape[0]}')

    # ── Save ──────────────────────────────────────────────────────────────────
    save_checkpoint({
        'X_matminer':             X_matminer,
        'matminer_feature_names': matminer_feature_names,
        'X_arr_combined':         X_arr_combined,
        'feature_names_combined': feature_names_combined,
    }, 'matminer_features')
    print('✓ matminer features saved to Drive.')

