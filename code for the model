# Active learning answers: which DFT calculations to run next
# to find the lowest-barrier SAA catalyst most efficiently.

al_ckpt = load_checkpoint('active_learning')

if al_ckpt is not None:
    al_history_df    = al_ckpt['al_history_df']
    recommendations  = al_ckpt['recommendations']
    cal_factor       = al_ckpt['cal_factor']
    print('✓ Active learning results loaded from Drive.')

else:
    # ── Load dependencies ─────────────────────────────────────────────────────
    try:
        X_arr; y_barrier; feature_names
    except NameError:
        ckpt = load_checkpoint('feature_matrix')
        if ckpt is None:
            print('ERROR: Feature matrix not found. Run Step 5 first.')
            raise SystemExit
        X_arr         = ckpt['X_arr']
        y_barrier     = ckpt['y_barrier']
        feature_names = ckpt['feature_names']
        X             = pd.DataFrame(X_arr, columns=feature_names)

    try:
        pred_mean; pred_std
    except NameError:
        uq_ckpt = load_checkpoint('uncertainty')
        if uq_ckpt is None:
            print('ERROR: Step 19 data not found. Run Step 19 first.')
            raise SystemExit
        pred_mean = uq_ckpt['pred_mean']
        pred_std  = uq_ckpt['pred_std']

    # ── Part A: Uncertainty Calibration (proper coverage test) ───────────────
    print('Part A: Calibrating uncertainty estimates...')

    abs_error = np.abs(pred_mean - y_barrier)

    # Find calibration factor: scale std so |error| / (s * std) ~ median 0.6745
    cal_factor = float(np.median(abs_error / (pred_std + 1e-8)) / 0.6745)
    pred_std_cal = pred_std * cal_factor

    # Coverage at 1-sigma and 2-sigma
    for n_sigma in [1, 2]:
        cov_raw = (abs_error <= n_sigma * pred_std).mean()
        cov_cal = (abs_error <= n_sigma * pred_std_cal).mean()
        expected = 0.683 if n_sigma == 1 else 0.954
        print(f'  {n_sigma}σ coverage: raw={cov_raw:.3f}  '
              f'calibrated={cov_cal:.3f}  expected={expected:.3f}')

    print(f'  Calibration factor: {cal_factor:.4f}')
    print(f'  Raw std mean      : {pred_std.mean():.4f} eV')
    print(f'  Calibrated std    : {pred_std_cal.mean():.4f} eV')

    # ── Part B: Active Learning Simulation ────────────────────────────────────
    print('\nPart B: Simulating active learning loop...')
    print('  Comparing: AL (uncertainty + exploitation) vs Random selection')

    N_INITIAL    = 100
    N_QUERY      = 5
    N_ITERATIONS = 20
    ALPHA        = 0.5   # 0=pure exploitation, 1=pure exploration, 0.5=balanced

    rng          = np.random.RandomState(SEED)
    n_total      = len(X_arr)

    # Initial labeled set (same for both AL and random)
    initial_idx   = rng.choice(n_total, N_INITIAL, replace=False)
    remaining_all = np.setdiff1d(np.arange(n_total), initial_idx)

    al_labeled    = list(initial_idx)
    rand_labeled  = list(initial_idx.copy())
    rand_remaining= list(remaining_all.copy())

    al_history  = []

    for iteration in tqdm(range(N_ITERATIONS + 1),
                          desc='AL iterations', ncols=80):

        # ── Train RF on current labeled set ───────────────────────────────────
        X_lab = X_arr[al_labeled]
        y_lab = y_barrier[al_labeled]

        rf_al = RandomForestRegressor(
            n_estimators=200, max_features='sqrt',
            min_samples_leaf=2, n_jobs=-1, random_state=SEED)
        rf_al.fit(X_lab, y_lab)

        # ── Predictions with uncertainty on remaining pool ────────────────────
        al_remaining = np.setdiff1d(np.arange(n_total), al_labeled)
        X_rem        = X_arr[al_remaining]

        tree_preds   = np.array([t.predict(X_rem)
                                  for t in rf_al.estimators_])
        mean_rem     = tree_preds.mean(axis=0)
        std_rem      = tree_preds.std(axis=0)

        # ── Best Ea found so far ──────────────────────────────────────────────
        al_best_ea   = y_barrier[al_labeled].min()
        rand_best_ea = y_barrier[rand_labeled].min()

        n_labeled = N_INITIAL + iteration * N_QUERY

        al_history.append({
            'iteration':    iteration,
            'n_labeled':    n_labeled,
            'al_best_ea':   round(float(al_best_ea), 5),
            'rand_best_ea': round(float(rand_best_ea), 5),
            'al_advantage': round(float(rand_best_ea - al_best_ea), 5),
        })

        if iteration < N_ITERATIONS:
            # ── AL acquisition: balanced uncertainty + exploitation ────────────
            # Normalize scores to [0,1]
            if std_rem.max() > std_rem.min():
                unc_score  = (std_rem - std_rem.min()) / (
                    std_rem.max() - std_rem.min())
            else:
                unc_score  = np.zeros_like(std_rem)

            if mean_rem.max() > mean_rem.min():
                exp_score  = 1 - (mean_rem - mean_rem.min()) / (
                    mean_rem.max() - mean_rem.min())
            else:
                exp_score  = np.ones_like(mean_rem)

            acq_score     = ALPHA * unc_score + (1 - ALPHA) * exp_score
            al_query_idx  = np.argsort(acq_score)[::-1][:N_QUERY]
            new_al        = al_remaining[al_query_idx]
            al_labeled.extend(new_al.tolist())

            # ── Random acquisition ────────────────────────────────────────────
            n_rand        = min(N_QUERY, len(rand_remaining))
            new_rand      = rng.choice(rand_remaining, n_rand, replace=False)
            rand_labeled.extend(new_rand.tolist())
            rand_remaining= [x for x in rand_remaining
                              if x not in new_rand]

    al_history_df = pd.DataFrame(al_history)

    print(f'\n  Initial labeled   : {N_INITIAL}')
    print(f'  Total after AL    : {N_INITIAL + N_ITERATIONS * N_QUERY}')
    print(f'  AL best Ea found  : {al_history_df["al_best_ea"].min():.4f} eV')
    print(f'  Random best Ea    : {al_history_df["rand_best_ea"].min():.4f} eV')
    print(f'  AL advantage      : '
          f'{al_history_df["al_advantage"].max():.4f} eV')

    # ── Part C: Final DFT Recommendations ────────────────────────────────────
    print('\nPart C: Generating DFT candidate recommendations...')

    # Train final AL model on all data seen so far
    rf_final_al = RandomForestRegressor(
        n_estimators=300, max_features='sqrt',
        min_samples_leaf=2, n_jobs=-1, random_state=SEED)
    rf_final_al.fit(X_arr[al_labeled], y_barrier[al_labeled])

    # Predict with uncertainty on ALL configurations
    tree_preds_all = np.array([t.predict(X_arr)
                                for t in rf_final_al.estimators_])
    pred_mean_al   = tree_preds_all.mean(axis=0)
    pred_std_al    = tree_preds_all.std(axis=0) * cal_factor  # calibrated

    # Acquisition score on full dataset
    if pred_std_al.max() > pred_std_al.min():
        unc_sc = (pred_std_al - pred_std_al.min()) / (
            pred_std_al.max() - pred_std_al.min())
    else:
        unc_sc = np.zeros_like(pred_std_al)

    if pred_mean_al.max() > pred_mean_al.min():
        exp_sc = 1 - (pred_mean_al - pred_mean_al.min()) / (
            pred_mean_al.max() - pred_mean_al.min())
    else:
        exp_sc = np.ones_like(pred_mean_al)

    acq_full = ALPHA * unc_sc + (1 - ALPHA) * exp_sc

    # Apply filters: low Ea AND low uncertainty
    EA_THRESHOLD  = float(np.percentile(y_barrier, 10))  # bottom 10% Ea
    UNC_THRESHOLD = float(np.percentile(pred_std_al, 30)) # bottom 30% uncertainty

    mask = (pred_mean_al <= EA_THRESHOLD) & \
           (pred_std_al  <= UNC_THRESHOLD)

    print(f'  Ea threshold       : {EA_THRESHOLD:.4f} eV (bottom 10%)')
    print(f'  Uncertainty thresh : {UNC_THRESHOLD:.4f} eV (bottom 30%)')
    print(f'  Candidates passing : {mask.sum()} / {len(mask)}')

    rec_scores = acq_full.copy()
    rec_scores[~mask] = -np.inf

    top10_idx = np.argsort(rec_scores)[::-1][:10]

    # Load screen_df for Host/Doped/Surface labels
    sc_ckpt = load_checkpoint('virtual_screening')
    if sc_ckpt is not None:
        screen_df = sc_ckpt['screen_df']
        rec_hosts   = screen_df.iloc[top10_idx]['Host'].values
        rec_dopants = screen_df.iloc[top10_idx]['Doped'].values
        rec_surfs   = screen_df.iloc[top10_idx]['Surface'].values
    else:
        rec_hosts   = host_labels[top10_idx]
        rec_dopants = ['N/A'] * 10
        rec_surfs   = surface_labels[top10_idx]

    recommendations = pd.DataFrame({
        'DFT_Priority':    range(1, 11),
        'Host':            rec_hosts,
        'Dopant':          rec_dopants,
        'Surface':         rec_surfs,
        'Pred_Barrier_eV': pred_mean_al[top10_idx].round(4),
        'Uncertainty_eV':  pred_std_al[top10_idx].round(4),
        'DFT_Barrier_eV':  y_barrier[top10_idx].round(4),
        'Acq_Score':       acq_full[top10_idx].round(4),
    })

    save_checkpoint({
        'al_history_df':   al_history_df,
        'recommendations': recommendations,
